# vLLM serving the local LLM. Uses devel base (not runtime) — vLLM source-compiles
# attention kernels for new architectures on first launch; sm_121 is new enough
# that pre-built wheels may not cover it.
FROM nvcr.io/nvidia/cuda:13.2.0-devel-ubuntu24.04

ENV DEBIAN_FRONTEND=noninteractive

RUN apt-get update -qq && apt-get install -y -qq --no-install-recommends \
      python3 python3-pip python3-dev ca-certificates && \
    rm -rf /var/lib/apt/lists/* /usr/lib/python3.12/EXTERNALLY-MANAGED

RUN python3 -m pip install --quiet --no-cache-dir uv==0.11.15

RUN uv pip install --system --no-cache "vllm>=0.6" "hf-transfer"

EXPOSE 8000
